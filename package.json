{
  "name": "playwright-tests-hybrid",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "ts-node ./src/utils/server.ts",
    "run": "tsx src/utils/test-runner.ts",
    "run:ui": "tsx src/utils/test-runner.ts --ui",
    "run:headed": "tsx src/utils/test-runner.ts --headed",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "codegen": "playwright codegen",
    "fmt": "prettier -w . --ignore-pattern .prettierignore",
    "lint": "eslint . --fix --max-warnings 0 --no-cache",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "logs:clean": "rimraf artifacts/logs",
    "prepare": "husky",
    "report:open": "npx monocart show-report artifacts/reports/monocart-report/index.json --open"
  },
  "dependencies": {
    "@playwright/test": "^1.58.1",
    "@apollo/client": "^3.8.0",
    "graphql": "^16.7.1",
    "cross-fetch": "^3.1.5",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.4.0",
    "eslint-plugin-jsonc": "^2.20.0",
    "adm-zip": "^0.5.16",
    "@types/adm-zip": "^0.5.7",
    "eslint": "^9.36.0",
    "@eslint/js": "^9.36.0",
    "globals": "^15.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^2.0.0",
    "prettier": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "@faker-js/faker": "^9.7.0",
    "chance": "^1.1.12",
    "moment": "^2.30.1",
    "cross-env": "^7.0.3",
    "lodash": "^4.17.21",
    "rimraf": "^6.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "kolorist": "^1.8.0",
    "express": "^5.2.1",
    "@types/express": "^5.0.6",
    "monocart-reporter": "^2.9.18",
    "typescript": "^5.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "@types/node": "^20.14.15",
    "@types/argparse": "^2.0.17",
    "typescript-eslint": "^8.8.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "fast-xml-parser": "^5.3.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint . --fix --max-warnings 0 --no-cache",
      "prettier -w . --ignore-pattern .prettierignore"
    ]
  }
}
